{
  "name": "3d-car-hill-climb",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "assets:vehicle": "node scripts/generate-vehicle.mjs",
    "coverage": "vitest run --coverage",
    "assets:terrain": "node scripts/generate-terrain.mjs",
    "assets:textures": "node scripts/generate-textures.mjs"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/three": "^0.169.0",
    "@vitest/coverage-v8": "^2.1.8",
    "fast-check": "^3.23.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.1.8"
  }
}
